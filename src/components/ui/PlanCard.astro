---
import checkIcon from "../../assets/svg/check.svg";
import xIcon from "../../assets/svg/x.svg";

export interface Props {
  nombre: string;
  precio: string;
  beneficios: { texto: string; incluido: boolean }[];
  esRecomendado?: boolean;
  mensajeWa: string;
}

const { nombre, precio, beneficios, esRecomendado = false, mensajeWa } = Astro.props;
const numeroWhatsapp = "51924985180";
const linkWa = `https://wa.me/${numeroWhatsapp}?text=${encodeURIComponent(mensajeWa)}`;
---

<article
  class={`relative flex flex-col h-full mt-6 p-8 rounded-sm bg-[#242121] transition-color duration-700 hover:border-[#EFD915] border-[1px] ${esRecomendado ? "border-[#EFD915] shadow-[0_0_40px_-10px_rgba(239,217,21,0.25)]" : "border-zinc-800"}`}
>
  {
    esRecomendado && (
      <div class="absolute -top-3.5 left-1/2 -translate-x-1/2 bg-[#EFD915] text-[#1D1A1A] font-bold uppercase tracking-widest text-[10px] md:text-xs px-4 py-1.5 rounded-sm">Recomendado</div>
    )
  }

  <div class="text-center mb-10 mt-4">
    <h3 class="text-xl md:text-2xl font-bold text-white uppercase tracking-wider mb-2" style="font-family: 'Orbitron', sans-serif;">{nombre}</h3>
    <p class={`text-3xl md:text-4xl font-black ${nombre === "Plan Pro" ? "text-[#EFD915]" : "text-white"}`} style="font-family: 'Orbitron', sans-serif;">
      {precio}
    </p>
  </div>

  <ul class="grow space-y-4 mb-10">
    {
      beneficios.map((beneficio) => (
        <li class={`flex items-start gap-3 text-sm md:text-base ${beneficio.incluido ? "text-zinc-300" : "text-zinc-600"}`}>
          {beneficio.incluido ? <img src={checkIcon.src} alt="Check" class="w-5 h-5 text-[#EFD915] shrink-0 mt-0.5" /> : <img src={xIcon.src} alt="X" class="w-5 h-5 text-zinc-600 shrink-0 mt-0.5" />}
          <span>{beneficio.texto}</span>
        </li>
      ))
    }
  </ul>

  <a
    href={linkWa}
    target="_blank"
    rel="noopener noreferrer"
    class={`w-full py-4 text-center font-bold uppercase tracking-widest text-sm rounded-sm transition-colors ${esRecomendado ? "bg-[#EFD915] text-[#1D1A1A] hover:bg-white" : "border border-[#EFD915] text-[#EFD915] hover:bg-[#EFD915] hover:text-[#1D1A1A]"}`}
  >
    Seleccionar
  </a>
</article>
